<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hikayat Journal Archive</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:        #1a1a18;
      --ink-light:  #6b6b65;
      --ink-faint:  #b8b8b0;
      --paper:      #f7f6f2;
      --paper-dim:  #e8e7e2;
      --accent:     #1d3f8a;
      --white:      #ffffff;

      --f-display: 'DM Serif Display', Georgia, serif;
      --f-body:    'DM Sans', system-ui, sans-serif;
      --f-mono:    'JetBrains Mono', monospace;
      --r: 6px;
      --t: 200ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: var(--f-body);
      background: var(--paper);
      color: var(--ink);
      font-size: 15px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* ── NAV ── */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(247,246,242,0.9);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--paper-dim);
      padding: 0 40px; height: 62px;
      display: flex; align-items: center; justify-content: space-between;
    }

    .nav-brand {
      text-decoration: none; color: var(--ink);
      display: flex; align-items: baseline; gap: 10px;
    }
    .nav-brand-word {
      font-family: var(--f-display);
      font-size: 20px; letter-spacing: -0.4px;
    }
    .nav-brand-sub {
      font-family: var(--f-mono);
      font-size: 10px; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--ink-faint);
    }

    .nav-right {
      display: flex; align-items: center; gap: 10px;
    }
    .btn-sm {
      padding: 6px 14px; border-radius: var(--r);
      font-family: var(--f-body); font-size: 13px; font-weight: 500;
      cursor: pointer; border: 1px solid var(--paper-dim);
      background: none; color: var(--ink);
      transition: all var(--t); text-decoration: none; display: inline-flex; align-items: center;
    }
    .btn-sm:hover { border-color: var(--ink); }
    .btn-sm.fill { background: var(--ink); color: var(--white); border-color: var(--ink); }
    .btn-sm.fill:hover { opacity: 0.75; }

    /* ── HERO ── */
    .hero {
      padding: 88px 40px 72px;
      max-width: 1120px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: end;
    }

    .hero-left {}
    .hero-eyebrow {
      font-family: var(--f-mono);
      font-size: 10.5px; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--accent);
      margin-bottom: 18px;
    }
    .hero-title {
      font-family: var(--f-display);
      font-size: clamp(38px, 5.5vw, 66px);
      line-height: 1.06; letter-spacing: -1.5px;
      margin-bottom: 22px;
    }
    .hero-title em { font-style: italic; color: var(--ink-light); }

    .hero-right {
      padding-bottom: 8px;
    }
    .hero-sub {
      font-size: 15px; font-weight: 300; color: var(--ink-light);
      line-height: 1.75; margin-bottom: 36px;
    }
    .hero-stats {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 1px; background: var(--paper-dim);
      border: 1px solid var(--paper-dim); border-radius: 8px; overflow: hidden;
    }
    .stat {
      background: var(--white); padding: 16px 20px;
      display: flex; flex-direction: column; gap: 3px;
    }
    .stat-num {
      font-family: var(--f-display); font-size: 28px;
      letter-spacing: -1px; line-height: 1;
    }
    .stat-label { font-size: 11px; color: var(--ink-light); }

    /* ── LOADING ── */
    .loading-bar {
      height: 2px; background: var(--paper-dim);
      position: fixed; top: 62px; left: 0; right: 0; z-index: 99;
      overflow: hidden;
    }
    .loading-bar::after {
      content: '';
      display: block; height: 100%; width: 40%;
      background: var(--accent);
      animation: slide 1.2s ease-in-out infinite;
    }
    @keyframes slide {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(350%); }
    }
    .loading-bar.hidden { display: none; }

    /* ── FILTER BAR ── */
    .filter-bar {
      border-top: 1px solid var(--paper-dim);
      border-bottom: 1px solid var(--paper-dim);
      background: var(--white);
      padding: 18px 40px;
      position: sticky; top: 62px; z-index: 90;
    }
    .filter-inner {
      max-width: 1120px; margin: 0 auto;
      display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    }
    .search-wrap { position: relative; flex: 1; min-width: 220px; }
    .search-ico {
      position: absolute; left: 11px; top: 50%; transform: translateY(-50%);
      color: var(--ink-faint); pointer-events: none;
    }
    .search-input {
      width: 100%; padding: 9px 12px 9px 34px;
      border: 1px solid var(--paper-dim); border-radius: var(--r);
      background: var(--paper); font-family: var(--f-body);
      font-size: 14px; color: var(--ink); outline: none;
      transition: border-color var(--t);
    }
    .search-input:focus { border-color: var(--accent); }
    .search-input::placeholder { color: var(--ink-faint); }

    .chips { display: flex; gap: 6px; flex-wrap: wrap; }
    .chip {
      padding: 5px 14px; border-radius: 100px;
      border: 1px solid var(--paper-dim);
      font-size: 12.5px; font-weight: 500; color: var(--ink-light);
      background: var(--paper); cursor: pointer;
      transition: all var(--t); white-space: nowrap;
    }
    .chip:hover { border-color: var(--ink-light); color: var(--ink); }
    .chip.on { background: var(--ink); border-color: var(--ink); color: var(--white); }

    .sort-sel {
      padding: 8px 12px; border: 1px solid var(--paper-dim);
      border-radius: var(--r); font-family: var(--f-body);
      font-size: 13px; color: var(--ink); background: var(--paper); outline: none; cursor: pointer;
    }

    /* ── GRID ── */
    .grid-section {
      max-width: 1120px; margin: 0 auto;
      padding: 36px 40px 96px;
    }
    .grid-meta {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 24px;
    }
    .grid-count { font-size: 13px; color: var(--ink-light); }
    .grid-count strong { color: var(--ink); }

    .journal-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
      gap: 1px; background: var(--paper-dim);
      border: 1px solid var(--paper-dim); border-radius: 10px; overflow: hidden;
    }

    /* ── CARD ── */
    .card {
      background: var(--white); padding: 28px;
      display: flex; flex-direction: column; gap: 12px;
      cursor: pointer; transition: background var(--t);
    }
    .card:hover { background: #fafaf8; }
    .card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; }
    .badge {
      font-family: var(--f-mono); font-size: 10px; font-weight: 500;
      letter-spacing: 0.08em; text-transform: uppercase;
      padding: 3px 10px; border-radius: 4px; white-space: nowrap;
    }
    .b-sains      { background:#edf2ff; color:#2b5ce6; }
    .b-sosial     { background:#fff4e6; color:#c26400; }
    .b-hukum      { background:#f0fff4; color:#2d8c4e; }
    .b-ekonomi    { background:#fff0f6; color:#c2266a; }
    .b-teknologi  { background:#f3f0ff; color:#6741d9; }
    .b-kesehatan  { background:#e6fcf5; color:#0c7a5e; }
    .b-pendidikan { background:#fff9db; color:#896a00; }
    .b-lain       { background:#f1f3f5; color:#495057; }

    .card-year { font-family: var(--f-mono); font-size: 11px; color: var(--ink-faint); }
    .card-title {
      font-family: var(--f-display); font-size: 18px;
      line-height: 1.3; letter-spacing: -0.3px;
    }
    .card-authors { font-size: 12.5px; color: var(--ink-light); font-weight: 300; }
    .card-abstract {
      font-size: 13px; color: var(--ink-light); line-height: 1.65;
      display: -webkit-box; -webkit-line-clamp: 3;
      -webkit-box-orient: vertical; overflow: hidden;
    }
    .card-foot {
      display: flex; align-items: center; justify-content: space-between;
      margin-top: auto; padding-top: 14px;
      border-top: 1px solid var(--paper-dim);
    }
    .card-doi {
      font-family: var(--f-mono); font-size: 10px; color: var(--ink-faint);
      text-decoration: none; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      max-width: 160px;
    }
    .card-doi:hover { color: var(--accent); }
    .card-acts { display: flex; gap: 6px; }
    .act {
      display: flex; align-items: center; gap: 5px;
      padding: 5px 11px; border-radius: 4px;
      font-size: 12px; font-weight: 500; cursor: pointer;
      border: 1px solid transparent; transition: all var(--t);
      text-decoration: none;
    }
    .act-link { background: var(--paper); border-color: var(--paper-dim); color: var(--ink); }
    .act-link:hover { border-color: var(--ink-light); }
    .act-dl { background: var(--ink); color: var(--white); }
    .act-dl:hover { opacity: 0.8; }

    /* ── EMPTY / ERROR ── */
    .state-box {
      padding: 80px 32px; text-align: center;
      color: var(--ink-light); display: none;
    }
    .state-box.show { display: block; }
    .state-box h3 { font-family: var(--f-display); font-size: 22px; margin-bottom: 8px; color: var(--ink); }
    .state-box p { font-size: 14px; margin-bottom: 20px; }
    .state-box a { color: var(--accent); }

    /* ── MODAL ── */
    .overlay {
      position: fixed; inset: 0;
      background: rgba(26,26,24,0.5);
      backdrop-filter: blur(5px);
      z-index: 200; display: flex;
      align-items: center; justify-content: center;
      padding: 24px; opacity: 0; pointer-events: none;
      transition: opacity var(--t);
    }
    .overlay.open { opacity: 1; pointer-events: all; }
    .modal {
      background: var(--white); border-radius: 12px;
      width: 100%; max-width: 700px; max-height: 90vh; overflow-y: auto;
      transform: translateY(14px); transition: transform var(--t);
    }
    .overlay.open .modal { transform: translateY(0); }

    .modal-hd {
      padding: 30px 32px 0;
      display: flex; align-items: flex-start; justify-content: space-between; gap: 16px;
    }
    .modal-close {
      background: var(--paper); border: none; width: 30px; height: 30px;
      border-radius: 50%; cursor: pointer; font-size: 18px; color: var(--ink-light);
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
      transition: background var(--t);
    }
    .modal-close:hover { background: var(--paper-dim); }
    .modal-bd { padding: 20px 32px 32px; }
    .modal-title {
      font-family: var(--f-display); font-size: 25px;
      line-height: 1.25; letter-spacing: -0.4px; margin-bottom: 16px;
    }
    .modal-metas {
      display: flex; gap: 28px; flex-wrap: wrap;
      padding-bottom: 20px; border-bottom: 1px solid var(--paper-dim); margin-bottom: 22px;
    }
    .meta-item { display: flex; flex-direction: column; gap: 2px; }
    .meta-lbl {
      font-family: var(--f-mono); font-size: 10px;
      letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-faint);
    }
    .meta-val { font-size: 14px; }
    .sec-lbl {
      font-size: 10.5px; font-weight: 600; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--ink-light); margin-bottom: 10px;
    }
    .modal-abstract { font-size: 14.5px; line-height: 1.78; font-weight: 300; margin-bottom: 24px; }
    .kw-wrap { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 28px; }
    .kw {
      padding: 4px 12px; background: var(--paper);
      border: 1px solid var(--paper-dim); border-radius: 100px;
      font-size: 12px; color: var(--ink-light);
    }
    .modal-cta { display: flex; gap: 10px; }
    .cta-dl {
      display: flex; align-items: center; gap: 8px;
      padding: 10px 20px; background: var(--ink); color: var(--white);
      border-radius: var(--r); font-size: 14px; font-weight: 500;
      text-decoration: none; transition: opacity var(--t); border: none; cursor: pointer;
      font-family: var(--f-body);
    }
    .cta-dl:hover { opacity: 0.8; }
    .cta-ext {
      display: flex; align-items: center; gap: 8px;
      padding: 10px 20px; background: none; color: var(--ink);
      border: 1px solid var(--paper-dim); border-radius: var(--r);
      font-size: 14px; font-weight: 500; text-decoration: none;
      transition: border-color var(--t); font-family: var(--f-body);
    }
    .cta-ext:hover { border-color: var(--ink); }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid var(--paper-dim);
      padding: 24px 40px;
      display: flex; align-items: center; justify-content: space-between;
    }
    footer p { font-size: 12px; color: var(--ink-faint); }

    /* ── RESPONSIVE ── */
    @media (max-width: 780px) {
      nav, .filter-bar, .grid-section, footer { padding-left: 20px; padding-right: 20px; }
      .hero { grid-template-columns: 1fr; padding: 52px 20px 40px; gap: 32px; }
      .hero-title { font-size: 40px; }
      .journal-grid { grid-template-columns: 1fr; }
      .modal-hd, .modal-bd { padding-left: 20px; padding-right: 20px; }
      .hero-stats { grid-template-columns: repeat(3,1fr); }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { transition: none !important; animation: none !important; }
    }
  </style>
</head>
<body>

<!-- LOADING BAR -->
<div class="loading-bar hidden" id="loadingBar"></div>

<!-- NAV -->
<nav>
  <a href="#" class="nav-brand">
    <span class="nav-brand-word">Hikayat</span>
    <span class="nav-brand-sub">Journal Archive</span>
  </a>
  <div class="nav-right">
    <a href="https://forms.gle/GANTI_LINK_FORM_LO" target="_blank" class="btn-sm fill">+ Submit Jurnal</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <p class="hero-eyebrow">Hikayat Journal Archive</p>
    <h1 class="hero-title">Arsip penelitian<br><em>yang hidup.</em></h1>
  </div>
  <div class="hero-right">
    <p class="hero-sub">Platform terbuka untuk mendokumentasikan, menemukan, dan merujuk karya-karya penelitian. Setiap jurnal adalah bagian dari hikayat pengetahuan yang terus berkembang.</p>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-num" id="sJurnal">—</span>
        <span class="stat-label">Jurnal</span>
      </div>
      <div class="stat">
        <span class="stat-num" id="sPenulis">—</span>
        <span class="stat-label">Peneliti</span>
      </div>
      <div class="stat">
        <span class="stat-num" id="sBidang">—</span>
        <span class="stat-label">Bidang</span>
      </div>
    </div>
  </div>
</section>

<!-- FILTER BAR -->
<div class="filter-bar">
  <div class="filter-inner">
    <div class="search-wrap">
      <svg class="search-ico" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input type="text" id="searchInput" class="search-input" placeholder="Cari judul, penulis, atau kata kunci…" />
    </div>
    <div class="chips" id="chips">
      <button class="chip on" data-f="semua">Semua</button>
    </div>
    <select class="sort-sel" id="sortSel">
      <option value="terbaru">Terbaru</option>
      <option value="terlama">Terlama</option>
      <option value="az">Judul A–Z</option>
    </select>
  </div>
</div>

<!-- GRID -->
<main class="grid-section">
  <div class="grid-meta">
    <p class="grid-count">Menampilkan <strong id="countTxt">—</strong> jurnal</p>
  </div>
  <div class="journal-grid" id="grid"></div>
  <div class="state-box" id="emptyBox">
    <h3>Tidak ada hasil</h3>
    <p>Coba kata kunci atau filter yang berbeda.</p>
  </div>
  <div class="state-box" id="errorBox">
    <h3>Gagal memuat data</h3>
    <p>Pastikan Google Sheets sudah dipublikasikan sebagai CSV.<br>
    Lihat file <strong>CARA-SETUP.md</strong> untuk panduan lengkap.</p>
  </div>
</main>

<!-- MODAL -->
<div class="overlay" id="overlay">
  <div class="modal">
    <div class="modal-hd">
      <div id="mBadge"></div>
      <button class="modal-close" id="mClose">×</button>
    </div>
    <div class="modal-bd">
      <h2 class="modal-title" id="mTitle"></h2>
      <div class="modal-metas" id="mMetas"></div>
      <p class="sec-lbl">Abstrak</p>
      <p class="modal-abstract" id="mAbstract"></p>
      <p class="sec-lbl">Kata Kunci</p>
      <div class="kw-wrap" id="mKw"></div>
      <div class="modal-cta" id="mCta"></div>
    </div>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <p>© 2024 Hikayat Journal Archive</p>
  <p>Ditenagai Google Sheets · Dihosting di GitHub Pages</p>
</footer>

<script>
  // ════════════════════════════════════════════════
  // ⚙️  KONFIGURASI — GANTI BAGIAN INI
  // ════════════════════════════════════════════════
  const SHEET_CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vS3NnGuIRou-yGn_Ly-YJFFwL18UWakhwrKK1UG0dIv_1KqaBICXdNUMzrRw3vczjFv44ZfTTjS-w7l/pub?gid=0&single=true&output=csv";
  // Contoh: "https://docs.google.com/spreadsheets/d/xxxx/export?format=csv&gid=0"
  // Cara dapat URL ini: lihat CARA-SETUP.md
  // ════════════════════════════════════════════════

  // Badge class berdasarkan nama bidang (case-insensitive)
  const BADGE = {
    sains:      "b-sains",
    sosial:     "b-sosial",
    hukum:      "b-hukum",
    ekonomi:    "b-ekonomi",
    teknologi:  "b-teknologi",
    kesehatan:  "b-kesehatan",
    pendidikan: "b-pendidikan",
  };

  function badgeClass(bidang) {
    if (!bidang) return "b-lain";
    return BADGE[bidang.toLowerCase()] || "b-lain";
  }

  // ── STATE ──
  let allData = [];
  let filtered = [];
  let activeFilter = "semua";
  let activeSearch = "";
  let activeSort = "terbaru";

  // ── ICONS ──
  const icoDl   = `<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`;
  const icoExt  = `<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`;

  // ── PARSE CSV ──
  function parseCSV(text) {
    const lines = text.trim().split("\n");
    if (lines.length < 2) return [];
    const headers = lines[0].split(",").map(h => h.replace(/"/g,"").trim().toLowerCase());

    return lines.slice(1).map((line, idx) => {
      // Handle commas inside quoted fields
      const cols = [];
      let cur = "", inQ = false;
      for (let i = 0; i < line.length; i++) {
        const c = line[i];
        if (c === '"') { inQ = !inQ; }
        else if (c === ',' && !inQ) { cols.push(cur.trim()); cur = ""; }
        else { cur += c; }
      }
      cols.push(cur.trim());

      const obj = { id: idx + 1 };
      headers.forEach((h, i) => { obj[h] = (cols[i] || "").replace(/^"|"$/g, "").trim(); });
      return obj;
    }).filter(r => r.judul); // skip empty rows
  }

  // ── LOAD FROM SHEETS ──
  async function loadData() {
    const lb = document.getElementById("loadingBar");
    lb.classList.remove("hidden");

    try {
      const res = await fetch(SHEET_CSV_URL);
      if (!res.ok) throw new Error("HTTP " + res.status);
      const text = await res.text();
      allData = parseCSV(text);

      // Hitung stats
      const totalPenulis = new Set(allData.flatMap(j => j.penulis.split(";").map(p => p.trim()))).size;
      const totalBidang  = new Set(allData.map(j => j.bidang)).size;

      animateCount("sJurnal",  allData.length);
      animateCount("sPenulis", totalPenulis);
      animateCount("sBidang",  totalBidang);

      buildChips();
      applyFilters();
    } catch(e) {
      console.error(e);
      document.getElementById("grid").style.display = "none";
      document.getElementById("errorBox").classList.add("show");
      document.getElementById("countTxt").textContent = "0";
    } finally {
      lb.classList.add("hidden");
    }
  }

  // ── BUILD FILTER CHIPS ──
  function buildChips() {
    const bidangSet = [...new Set(allData.map(j => j.bidang).filter(Boolean))].sort();
    const wrap = document.getElementById("chips");
    wrap.innerHTML = `<button class="chip on" data-f="semua">Semua</button>`;
    bidangSet.forEach(b => {
      const btn = document.createElement("button");
      btn.className = "chip";
      btn.dataset.f = b;
      btn.textContent = b;
      wrap.appendChild(btn);
    });
    wrap.querySelectorAll(".chip").forEach(c => {
      c.addEventListener("click", () => {
        wrap.querySelectorAll(".chip").forEach(x => x.classList.remove("on"));
        c.classList.add("on");
        activeFilter = c.dataset.f;
        applyFilters();
      });
    });
  }

  // ── FILTER + SORT ──
  function applyFilters() {
    filtered = allData.filter(j => {
      const okF = activeFilter === "semua" || j.bidang === activeFilter;
      const q = activeSearch.toLowerCase();
      const okQ = !q ||
        j.judul?.toLowerCase().includes(q) ||
        j.penulis?.toLowerCase().includes(q) ||
        j["kata kunci"]?.toLowerCase().includes(q);
      return okF && okQ;
    });

    if (activeSort === "terbaru") filtered.sort((a,b) => (b.tahun||0) - (a.tahun||0));
    else if (activeSort === "terlama") filtered.sort((a,b) => (a.tahun||0) - (b.tahun||0));
    else filtered.sort((a,b) => (a.judul||"").localeCompare(b.judul||"", "id"));

    renderGrid();
  }

  // ── RENDER GRID ──
  function renderGrid() {
    const grid  = document.getElementById("grid");
    const empty = document.getElementById("emptyBox");
    document.getElementById("countTxt").textContent = filtered.length;

    if (filtered.length === 0) {
      grid.innerHTML = ""; grid.style.display = "none";
      empty.classList.add("show"); return;
    }
    grid.style.display = "grid";
    empty.classList.remove("show");

    grid.innerHTML = filtered.map(j => {
      const hasPDF  = j.pdf && j.pdf !== "-" && j.pdf !== "";
      const hasLink = j.link && j.link !== "-" && j.link !== "";
      return `
      <article class="card" data-id="${j.id}" tabindex="0" role="button" aria-label="${j.judul}">
        <div class="card-top">
          <span class="badge ${badgeClass(j.bidang)}">${j.bidang || "Umum"}</span>
          <span class="card-year">${j.tahun || ""}</span>
        </div>
        <h3 class="card-title">${j.judul}</h3>
        <p class="card-authors">${j.penulis}</p>
        <p class="card-abstract">${j.abstrak}</p>
        <div class="card-foot">
          <span class="card-doi">${j.doi ? "doi: " + j.doi : ""}</span>
          <div class="card-acts">
            ${hasLink ? `<a href="${j.link}" class="act act-link" target="_blank" rel="noopener" onclick="event.stopPropagation()">${icoExt} Lihat</a>` : ""}
            ${hasPDF  ? `<a href="${j.pdf}"  class="act act-dl"   target="_blank" rel="noopener" onclick="event.stopPropagation()">${icoDl} PDF</a>` : ""}
          </div>
        </div>
      </article>`;
    }).join("");

    grid.querySelectorAll(".card").forEach(c => {
      c.addEventListener("click", () => openModal(parseInt(c.dataset.id)));
      c.addEventListener("keydown", e => { if(e.key==="Enter"||e.key===" ") openModal(parseInt(c.dataset.id)); });
    });
  }

  // ── MODAL ──
  function openModal(id) {
    const j = allData.find(x => x.id === id);
    if (!j) return;

    const hasPDF  = j.pdf  && j.pdf  !== "-" && j.pdf  !== "";
    const hasLink = j.link && j.link !== "-" && j.link !== "";

    document.getElementById("mBadge").innerHTML =
      `<span class="badge ${badgeClass(j.bidang)}">${j.bidang || "Umum"}</span>`;
    document.getElementById("mTitle").textContent = j.judul;
    document.getElementById("mMetas").innerHTML = `
      <div class="meta-item"><span class="meta-lbl">Penulis</span><span class="meta-val">${j.penulis}</span></div>
      <div class="meta-item"><span class="meta-lbl">Tahun</span><span class="meta-val">${j.tahun}</span></div>
      ${j.doi ? `<div class="meta-item"><span class="meta-lbl">DOI</span><span class="meta-val">${j.doi}</span></div>` : ""}
      ${j.penerbit ? `<div class="meta-item"><span class="meta-lbl">Penerbit</span><span class="meta-val">${j.penerbit}</span></div>` : ""}
    `;
    document.getElementById("mAbstract").textContent = j.abstrak;
    document.getElementById("mKw").innerHTML =
      (j["kata kunci"] || "").split(";").filter(Boolean)
        .map(k => `<span class="kw">${k.trim()}</span>`).join("");
    document.getElementById("mCta").innerHTML = `
      ${hasPDF  ? `<a href="${j.pdf}"  class="cta-dl"  target="_blank" rel="noopener">${icoDl} Unduh PDF</a>` : ""}
      ${hasLink ? `<a href="${j.link}" class="cta-ext" target="_blank" rel="noopener">${icoExt} Buka di sumber</a>` : ""}
    `;

    document.getElementById("overlay").classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    document.getElementById("overlay").classList.remove("open");
    document.body.style.overflow = "";
  }

  document.getElementById("mClose").addEventListener("click", closeModal);
  document.getElementById("overlay").addEventListener("click", e => { if(e.target===e.currentTarget) closeModal(); });
  document.addEventListener("keydown", e => { if(e.key==="Escape") closeModal(); });

  // ── SEARCH ──
  let searchT;
  document.getElementById("searchInput").addEventListener("input", e => {
    clearTimeout(searchT);
    searchT = setTimeout(() => { activeSearch = e.target.value; applyFilters(); }, 250);
  });

  // ── SORT ──
  document.getElementById("sortSel").addEventListener("change", e => { activeSort = e.target.value; applyFilters(); });

  // ── COUNT ANIMATION ──
  function animateCount(elId, target) {
    const el = document.getElementById(elId);
    let n = 0; const step = Math.max(1, Math.ceil(target/40));
    const t = setInterval(() => {
      n = Math.min(n + step, target);
      el.textContent = n;
      if(n >= target) clearInterval(t);
    }, 30);
  }

  // ── INIT ──
  loadData();
</script>
</body>
</html>
